# API — local dev uses Vite proxy (/api). Production on Vercel uses serverless proxy + BACKEND_URL on Vercel dashboard.
VITE_API_URL=/api
# WebSocket must point to Spring Boot host (not Vercel). Example: wss://your-app.up.railway.app/ws
VITE_WS_URL=

# Sentry (https://sentry.io)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# PostHog (https://posthog.com)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase — optional Realtime only (https://supabase.com)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
